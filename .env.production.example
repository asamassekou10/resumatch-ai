# =============================================================================
# Production Environment Variables
# Copy this to .env.production and fill in real values
# NEVER commit .env.production to git
# =============================================================================

# --- Database ---
POSTGRES_DB=resume_optimizer
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# --- Flask ---
SECRET_KEY=CHANGE_ME_GENERATE_WITH_python3_-c_"import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_GENERATE_WITH_python3_-c_"import secrets; print(secrets.token_hex(32))"

# --- AI ---
GEMINI_API_KEY=your_gemini_api_key

# --- Google OAuth ---
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# --- Stripe ---
STRIPE_PUBLISHABLE_KEY=pk_live_xxx
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- Email (Resend) ---
RESEND_API_KEY=re_xxx
FROM_EMAIL=support@resumeanalyzerai.com

# --- LinkedIn OAuth (optional) ---
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# --- Job APIs (optional) ---
RAPIDAPI_KEY=
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
